{
  "name": "reaction-moderator",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:bot": "turbo run build --filter=bot"
  },
  "devDependencies": {
    "@types/react-window": "^2.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@discordapp/twemoji": "^16.0.1",
    "emoji-datasource": "^16.0.0",
    "react-window": "^2.2.7"
  }
}
