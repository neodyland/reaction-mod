{
  "name": "@repo/db",
  "version": "0.0.0",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prisma": "^7.5.0"
  },
  "scripts": {
    "db:generate": "bun --env-file=../../.env prisma generate",
    "db:migrate": "bun --env-file=../../.env prisma migrate dev",
    "db:deploy": "bun --env-file=../../.env prisma migrate deploy"
  },
  "dependencies": {
    "@repo/env": "*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  }
}
